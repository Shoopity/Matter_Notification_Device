menu "Example Configuration"

    config ENABLE_MEMORY_PROFILING
        bool "Enable Memory Profiling"
        default n
        help
            Enable this option to include memory profiling features in the example.
            This will allow you to monitor memory usage during runtime.

endmenu

menu "Board Configuration"
    config BOARD_LED_PIN
        int "Status LED Pin"
        default 15
        help
            The GPIO pin for the status LED.

    config BOARD_LED_TYPE_WS2812
        bool "Addressable RGB (WS2812)"
        default n
        help
            Select this if your board uses an addressable WS2812 for the status LED.

    config BOARD_BUTTON_PIN
        int "Physical Button Pin"
        default 9
        help
            The GPIO pin for the physical button.

    config BOARD_MATTER_DISCRIMINATOR
        int "Matter Setup Discriminator"
        default 3841
        help
            The 12-bit Matter setup discriminator (0-4095) used for pairing. 
            Change this if you are deploying multiple devices to avoid conflicts.
endmenu
