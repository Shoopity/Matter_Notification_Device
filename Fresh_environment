# 1. Fire up a completely clean Ubuntu instance; from a Windows Command Prompt:
wsl --install -d Ubuntu-22.04
# provide new credentials
exit
# Install usbipd on Windows
# Check here: https://github.com/dorssel/usbipd-win/releases
usbipd list
# Note the attached ESP32 device
# Possibly clear out previous bindings
# usbipd unbind -a
usbipd bind --busid <BUSID>
usbipd attach --wsl Ubuntu-22.04 --busid <BUSID>

wsl
cd ~
# Run these two lines without anything else, mainly to get the credentials for sudo cached
sudo apt-get update
sudo apt-get upgrade -y

######## You can Copy/Past the rest from here down to the ./install.sh command for Matter,
######## Unless you're 100% sure installing Matter can be completed with only one run,
######## then you can go all the way to the bottom

# Install pre-reqs for Matter
# sudo apt-get install -y git gcc g++ pkg-config cmake curl libssl-dev libdbus-1-dev \
#     libglib2.0-dev libavahi-client-dev ninja-build python3.11 python3.11-venv python3.11-dev \
#     python3-pip unzip libgirepository1.0-dev libcairo2-dev libreadline-dev \
#     libevent-dev default-jre
sudo apt-get install -y git gcc g++ pkg-config cmake curl libssl-dev libdbus-1-dev \
     libglib2.0-dev libavahi-client-dev ninja-build python3-venv python3-dev \
     python3.11 python3.11-venv python3.11-dev \
     python3-pip unzip libgirepository1.0-dev libcairo2-dev libreadline-dev \
     libevent-dev default-jre

# Make a temp to make python 3.11 the default
mkdir -p ~/.local/bin
ln -sf /usr/bin/python3.11 ~/.local/bin/python3
export PATH=~/.local/bin:$PATH

# Allow the user to write to the USB
sudo usermod -a -G dialout $USER
sudo usermod -a -G plugdev $USER
# restart WSL, or run:
# su - $USER
	
# Create a folder to hold ESP stuff
mkdir ~/esp
cd ~/esp
# ESP-IDF setup; I've chosen the Matter/IDF paring of 1.5/5.4.1
git clone --branch v5.4.1 --recursive https://github.com/espressif/esp-idf.git
cd ~/esp/esp-idf
./install.sh
. ./export.sh
cd ~/esp

# Matter Setup
git clone --branch release/v1.5 --depth 1 https://github.com/espressif/esp-matter.git
cd esp-matter
git submodule update --init --depth 1

# Download ConnectedHomeIP platform dependencies
cd connectedhomeip/connectedhomeip
./scripts/checkout_submodules.py --platform esp32 linux --shallow
cd ~

# Install Matter
cd ~/esp/esp-matter
./install.sh
# Depending on your environement, you might run out of memory
# If you do, run the following command plus the above install command again (you meed to do this more than twice)
# rm -rf ~/esp-matter/connectedhomeip/connectedhomeip/.environment/
. ./export.sh

# Get this repo
mkdir ~/code
cd ~/code
git clone --recursive https://github.com/Shoopity/Matter_Notification_Device.git
cd ~

# Clean up project cache artifacts
cd ~/code/Matter_Notification_Device/generic_switch
rm -rf build sdkconfig sdkconfig.old managed_components dependencies.lock .shadow-plugin-configured

# Config flasher for a 4 MB partition
# Commented out because I just added this to the sdkconfig.defaults in this repository, but leaving in the likely event I have no idea what I'm doing
# if [ -f "sdkconfig.defaults" ]; then
#     sed -i '/CONFIG_ESPTOOLPY_FLASHSIZE/d' sdkconfig.defaults
# fi
# echo "CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y" >> sdkconfig.defaults
# echo "CONFIG_ESPTOOLPY_FLASHSIZE=\"4MB\"" >> sdkconfig.defaults

# Create an alias to run every time you open a command prompt; just type "load-matter" the next time you open a terminal
echo 'alias load-matter="export PATH=~/.local/bin:\$PATH && . ~/esp/esp-idf/export.sh && . ~/esp/esp-matter/export.sh"' >> ~/.bashrc
source ~/.bashrc

# Because you gave access to the USB above, you'll need to log out/in; now's a good time to do that

